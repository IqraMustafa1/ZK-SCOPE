  [string]$secret, [string]$ledgerId, [string]$participantId,
  [string]$appId, [string]$operatorId, [int]$lifetime
) {
  $now = [int][DateTimeOffset]::UtcNow.ToUnixTimeSeconds()
  $hdr = @{ alg="HS256"; typ="JWT" } | ConvertTo-Json -Compress
  $pl  = @{
    iss = "local-script"; aud = "json-api"; exp = ($now + $lifetime)
    "https://daml.com/ledger-api" = @{
      ledgerId      = $ledgerId
      participantId = $participantId
      applicationId = $appId
      admin         = $true
      actAs         = @($operatorId)
      readAs        = @($operatorId)
    }
  } | ConvertTo-Json -Compress
  $head = B64UrlText $hdr
  $pay  = B64UrlText $pl
  $sig  = HmacSha256 "$head.$pay" $secret
  "$head.$pay.$sig"
}

