function Convert-PathToWsl([string]$winPath) {
  $p = Resolve-Path $winPath
  $p = $p.Path
  if ($p -match '^[A-Za-z]:\\') {
    $drive = $p.Substring(0,1).ToLower()
    $tail = $p.Substring(2) -replace '\\','/'
    return "/mnt/$drive$tail"
  }
  return $winPath
}

function Get-WindowsHostIpForWsl() {
  try {
    $ip = & wsl.exe bash -lc "grep -m1 nameserver /etc/resolv.conf | awk '{print \$2}'" 2>$null
    $ip = ($ip | Select-Object -First 1).Trim()
    if ($ip -match '^\d+\.\d+\.\d+\.\d+$') { return $ip }
  } catch {}
  return $null
}

function Get-LatestEpoch([string]$apiBase, $headers, [string]$tidTaSnapshot) {
  try {
    $res = JsonQuery -apiBase $apiBase -headers $headers -tids @($tidTaSnapshot)
    $rows = Get-ResultArray $res
    if ($res.result -and $res.result.Count -gt 0) {
      return ($res.result | Sort-Object { $_.payload.epoch } -Descending | Select-Object -First 1).payload.epoch
    }
  } catch {}
  return 0
}

function Get-MerkleRootForEpoch([string]$apiBase, $headers, [string]$tidTaSnapshot, [int]$epoch) {
  try {
    $res = JsonQuery -apiBase $apiBase -headers $headers -tids @($tidTaSnapshot)
    if ($res.result -and $res.result.Count -gt 0) {
      $hit = $res.result | Where-Object { [int]$_.payload.epoch -eq $epoch } | Select-Object -First 1
      if ($hit -and $hit.payload.merkleRoot) { return [string]$hit.payload.merkleRoot }
      $latest = $res.result | Sort-Object { $_.payload.epoch } -Descending | Select-Object -First 1
      if ($latest -and $latest.payload.merkleRoot) { return [string]$latest.payload.merkleRoot }
    }
  } catch {}
  return "genesis"
}

# ---- FIX: Ratchet counter from ledger (edge, deviceKey, senderId, epoch) ----
function Get-NextRatchetCounter(
  [string]$apiBase, $headers,
  [string]$tidRatchetState,
  [string]$edge, [string]$deviceKey, [string]$senderId,
  [int]$epoch
) {
  $resR  = JsonQuery -apiBase $apiBase -headers $headers -tids @($tidRatchetState)
  $rowsR = @()
  if ($resR -and $resR.result) { $rowsR = @($resR.result) }

  $hitR = $rowsR | Where-Object {
    $_.payload.edge      -eq $edge -and
    $_.payload.deviceKey -eq $deviceKey -and
    $_.payload.senderId  -eq $senderId -and
    [int]$_.payload.epoch -eq $epoch
  } | Sort-Object { [int]$_.payload.lastCtr } -Descending | Select-Object -First 1

  $lastCtr = if ($hitR) { [int]$hitR.payload.lastCtr } else { 0 }
  $nextCtr = $lastCtr + 1
  Write-Host "Ratchet lastCtr=$lastCtr -> using counter=$nextCtr"
  return $nextCtr
}

