<#  test_flask_operator.ps1
    Fixed/Improved:
      ✅ JSON depth everywhere (prevents PS depth=2 breaking nested JSON -> 400)
      ✅ No-null relay fields (strict Flask validators often reject null)
      ✅ merkleRoot resolve per epoch (never null; "genesis" fallback)
      ✅ WSL ledger host auto-map (localhost -> Windows host IP for WSL Flask)
      ✅ SAFETY: mint bootstrap multi-party token only when needed
      ✅ FIX: Main:setup ALWAYS uses bootstrap (multi-party) token (setup submits as IoTDevice1 etc.)
      ✅ FIX: JSON-API list endpoints sometimes return {result:[...]} -> handle counts correctly
      ✅ NEW: Ensure SigAttestation matches CURRENT digest (not placeholder/older digest)
      ✅ NEW: Auto-create missing attestations for the CURRENT digest using a multi-party token (actAs issuers + Operator)
      ✅ NEW: DUPLICATE_CONTRACT_KEY resilient attestation creation (re-query existing and continue)
      ✅ NEW: Always send JSON-API contractIds to Flask (never #1:0)
      ✅ FIX: Ratchet counter is now ALWAYS ledger-derived and enforced in /crypto/prepare_hybrid and /relay_message
#>

param(
  [string]$LedgerHost         = "localhost",
  [int]   $LedgerHttpPort     = 7576,      # JSON-API
  [string]$OperatorTokenPath  = ".\operator.jwt",
