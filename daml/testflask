# ── helpers ────────────────────────────────────────────────────────────────
function Get-NewestDar([string]$pattern) {
  try {
    Get-ChildItem -Path $pattern -File -ErrorAction Stop |
      Sort-Object LastWriteTime -Descending |
      Select-Object -First 1
  } catch { $null }
}

function JsonApi-GET($apiBase, $headers, $path) {
  Invoke-RestMethod -Uri ($apiBase + $path) -Headers $headers -TimeoutSec 15
}

function JsonApi-POST($apiBase, $headers, $path, $bodyObj) {
  $body = $bodyObj | ConvertTo-Json -Depth $Global:JSON_DEPTH -Compress
  Invoke-RestMethod -Method Post -Uri ($apiBase + $path) -Headers $headers `
    -ContentType "application/json" -Body $body -TimeoutSec 30
}

# NEW: JSON-API sometimes returns {result:[...]} rather than an array
function Get-ResultArray($resp) {
  if ($null -eq $resp) { return @() }

  if ($resp -is [System.Array]) { return $resp }

  if ($resp.PSObject.Properties.Match('result').Count -gt 0) {
    $r = $resp.result
    if ($null -eq $r) { return @() }
    if ($r -is [System.Array]) { return $r }
    return @($r)
  }

  return @($resp)
}

# base64url + JWT helpers
function B64Url([byte[]]$bytes) {
  ([Convert]::ToBase64String($bytes)).TrimEnd("=") -replace "\+","-" -replace "/","_"
}
function B64UrlText([string]$s) {
  B64Url ([System.Text.Encoding]::UTF8.GetBytes($s))
}
function HmacSha256([string]$data, [string]$secret) {
  $keyBytes  = [System.Text.Encoding]::UTF8.GetBytes($secret)
  $dataBytes = [System.Text.Encoding]::UTF8.GetBytes($data)
  try { $mac = [System.Security.Cryptography.HMACSHA256]::new([byte[]]$keyBytes) }
  catch { $mac = New-Object System.Security.Cryptography.HMACSHA256 -ArgumentList (,[byte[]]$keyBytes) }
  $hash = $mac.ComputeHash($dataBytes)
  B64Url $hash
}

function New-AdminJwt([string]$secret, [string]$ledgerId, [string]$participantId, [string]$appId, [int]$lifetime) {
  $now = [int][DateTimeOffset]::UtcNow.ToUnixTimeSeconds()
  $hdr = @{ alg="HS256"; typ="JWT" } | ConvertTo-Json -Compress
  $pl  = @{
    iss = "bootstrap"; aud = "json-api"; exp = ($now + $lifetime)
    "https://daml.com/ledger-api" = @{
      ledgerId      = $ledgerId
      participantId = $participantId
      applicationId = $appId
      admin         = $true
    }
  } | ConvertTo-Json -Compress
  $head = B64UrlText $hdr
  $pay  = B64UrlText $pl
  $sig  = HmacSha256 "$head.$pay" $secret
  "$head.$pay.$sig"
}

