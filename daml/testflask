# ---- Attestation helpers (digest-aware + duplicate-safe) ----
function Get-HttpErrorBodyText($err) {
  try {
    $resp = $err.Exception.Response
    if ($resp -and $resp.GetResponseStream()) {
      $sr = New-Object System.IO.StreamReader($resp.GetResponseStream())
      return $sr.ReadToEnd()
    }
  } catch {}
  return $null
}

function Find-SigAttestationCid(
  [string]$apiBase, $headers,
  [string]$tid, [string]$issuer, [string]$digest,
  [string]$deviceOwner, [string]$devicePublicKey,
  [string]$operator, [string]$algId
) {
  $res = JsonQuery -apiBase $apiBase -headers $headers -tids @($tid)
  $rows = @()
  if ($res -and $res.result) { $rows = $res.result }

  $hit = $rows | Where-Object {
    $_.payload.issuer          -eq $issuer -and
    $_.payload.digest          -eq $digest -and
    $_.payload.deviceOwner     -eq $deviceOwner -and
    $_.payload.devicePublicKey -eq $devicePublicKey -and
    $_.payload.operator        -eq $operator -and
    $_.payload.algId           -eq $algId
  } | Sort-Object { $_.payload.ts } -Descending | Select-Object -First 1

  if ($hit) { return $hit.contractId }
  return $null
}

function Find-SigAttestationCidsForDigest(
  [string]$apiBase, $headers,
  [string]$tid, [string]$digest,
  [string]$deviceOwner, [string]$devicePublicKey,
  [string]$operator, [string]$algId
) {
  $res = JsonQuery -apiBase $apiBase -headers $headers -tids @($tid)
  $rows = @()
  if ($res -and $res.result) { $rows = $res.result }

  $hits = $rows | Where-Object {
    $_.payload.digest          -eq $digest -and
    $_.payload.deviceOwner     -eq $deviceOwner -and
    $_.payload.devicePublicKey -eq $devicePublicKey -and
    $_.payload.operator        -eq $operator -and
    $_.payload.algId           -eq $algId
  } | Sort-Object { $_.payload.ts } -Descending

  return @($hits)
}

function Ensure-SigAttestationForDigest(
  [string]$apiBase, $attestHeaders,
  [string]$tid, [string]$issuer, [string]$digest,
  [string]$deviceOwner, [string]$devicePublicKey,
  [string]$operator, [string]$algId,
  [string]$senderPublicKey
) {
  $existing = Find-SigAttestationCid -apiBase $apiBase -headers $attestHeaders -tid $tid `
    -issuer $issuer -digest $digest -deviceOwner $deviceOwner -devicePublicKey $devicePublicKey -operator $operator -algId $algId
  if ($existing) { return $existing }

  $now = (Get-Date).ToUniversalTime()
  $ts = $now.ToString("yyyy-MM-ddTHH:mm:ssZ")
  $expires = $now.AddMinutes(10).ToString("yyyy-MM-ddTHH:mm:ssZ")

  $createBody = @{
    templateId = $tid
    payload    = @{
      expires         = $expires
      digest          = $digest
      ts              = $ts
      issuer          = $issuer
      devicePublicKey = $devicePublicKey
      deviceOwner     = $deviceOwner
      senderPublicKey = $senderPublicKey
      operator        = $operator
      algId           = $algId
    }
  }

  try {
    $resp = JsonApi-POST $apiBase $attestHeaders "/v1/create" $createBody
    if ($resp.result -and $resp.result.contractId) { return $resp.result.contractId }
    throw "Create returned unexpected shape (no result.contractId)."
  } catch {
    $msg = $_.Exception.Message
    $txt = Get-HttpErrorBodyText $_
    if (($msg -match 'DUPLICATE_CONTRACT_KEY|ALREADY_EXISTS|409') -or ($txt -match 'DUPLICATE_CONTRACT_KEY|ALREADY_EXISTS')) {
      $again = Find-SigAttestationCid -apiBase $apiBase -headers $attestHeaders -tid $tid `
        -issuer $issuer -digest $digest -deviceOwner $deviceOwner -devicePublicKey $devicePublicKey -operator $operator -algId $algId
      if ($again) { return $again }
    }
    throw
  }
}

# === Prepare-hybrid helper that ENFORCES ledger counter ===
function Prepare-Hybrid-EnforceCounter(
  [int]$ctrToUse,
  [int]$epochToUse,
  [string]$deviceX25519,
  $ctxObj,
  [string]$aadPlain,
  [string]$ptPlain,
  [string]$kemAlg,
  [string]$sigAlg,
  [string]$deviceKyberPubB64,
  [string]$deviceKyberPubB64u
) {
  # Try multiple schema variants, each with counter field variants (counter/ctr/msg_counter)
  $variants = @()

  # Variant A (camel fields)
  $a1 = @{
    _name            = "A1-camel-counter"
    kem              = $kemAlg
    alg              = $sigAlg
    sig_alg          = $sigAlg
    devicePublicKey  = $deviceX25519
    plaintext        = $ptPlain
    plaintext_is_b64 = $false
    aad              = $aadPlain
    ctx              = $ctxObj
    epoch            = [int]$epochToUse
    counter          = [int]$ctrToUse
  }
  if ($deviceKyberPubB64) { $a1.device_pq_pub_b64 = $deviceKyberPubB64 }
  $variants += $a1

  $a2 = $a1.Clone(); $a2["_name"]="A2-camel-ctr"; $a2.Remove("counter"); $a2["ctr"]=[int]$ctrToUse
  $variants += $a2

  # Variant B (snake hex)
  $b1 = @{
    _name                 = "B1-snake-hex-counter"
    kem                   = $kemAlg
    alg                   = $sigAlg
    sig_alg               = $sigAlg
    device_public_key_hex = $deviceX25519
    plaintext             = $ptPlain
    plaintext_is_b64      = $false
    aad                   = $aadPlain
    ctx                   = $ctxObj
    epoch                 = [int]$epochToUse
    counter               = [int]$ctrToUse
  }
  if ($deviceKyberPubB64u) { $b1.device_pq_pub_b64u = $deviceKyberPubB64u }
  $variants += $b1

  $b2 = $b1.Clone(); $b2["_name"]="B2-snake-hex-ctr"; $b2.Remove("counter"); $b2["ctr"]=[int]$ctrToUse
  $variants += $b2

  # Variant C (plaintext b64u)
  $ptB64u  = To-B64Url $ptPlain
  $aadB64u = To-B64Url $aadPlain
  $c1 = @{
    _name                 = "C1-ptb64u-counter"
    kem                   = $kemAlg
    alg                   = $sigAlg
    sig_alg               = $sigAlg
    device_public_key_hex = $deviceX25519
    plaintext             = $ptB64u
    plaintext_is_b64      = $true
    aad_b64u              = $aadB64u
    ctx                   = $ctxObj
    epoch                 = [int]$epochToUse
    counter               = [int]$ctrToUse
  }
  if ($deviceKyberPubB64u) { $c1.device_pq_pub_b64u = $deviceKyberPubB64u }
  $variants += $c1

  # Variant D (no epoch sometimes accepted when epoch=0)
  $d1 = @{
    _name                 = "D1-no-epoch-counter"
    kem                   = $kemAlg
    alg                   = $sigAlg
    sig_alg               = $sigAlg
    device_public_key_hex = $deviceX25519
    plaintext             = $ptPlain
    plaintext_is_b64      = $false
    aad                   = $aadPlain
    ctx                   = $ctxObj
    counter               = [int]$ctrToUse
  }
  if ($deviceKyberPubB64) { $d1.device_pq_pub_b64 = $deviceKyberPubB64 }
  $variants += $d1

  # Try with tolerant helper: primary first item, rest alternates
  $primary = $variants[0]
  $alts = @()
  for ($i=1; $i -lt $variants.Count; $i++) { $alts += $variants[$i] }

  $try = Invoke-PostJson-Tolerant -uri (Url-Flask "/crypto/prepare_hybrid") -primary $primary -alternates $alts
  return $try
}

# ---------------- MAIN ----------------
$API_BASE = "http://{0}:{1}" -f $LedgerHost, $LedgerHttpPort

# Auto-load DeviceKyberPubB64 if empty
if (-not $DeviceKyberPubB64 -or -not $DeviceKyberPubB64.Trim()) {
  $pubPath = Join-Path $scriptDir "device_kem768_pub.b64"
  if (Test-Path -LiteralPath $pubPath) {
    $DeviceKyberPubB64 = (Get-Content -Raw -LiteralPath $pubPath).Trim()
  }
}

# Try existing Operator token
$haveToken  = Test-Path -LiteralPath $OperatorTokenPath
$OP_TOKEN   = $null
$OP_HEADERS = $null
$ADMIN_HEADERS = $null

if ($haveToken) {
  $OP_TOKEN   = (Get-Content -Raw -LiteralPath $OperatorTokenPath).Trim()
  $OP_HEADERS = @{ Authorization = "Bearer $OP_TOKEN"; "Content-Type"="application/json" }
  try {
    Write-Host "== JSON-API sanity with existing token =="
    $packagesResp = JsonApi-GET $API_BASE $OP_HEADERS "/v1/packages"
    $pkgArr = Get-ResultArray $packagesResp
    Write-Host ("Packages visible: {0}" -f $pkgArr.Count)
  } catch {
    Write-Warning "Existing token failed against JSON-API. Will bootstrap with an admin JWT."
    $haveToken = $false
  }
}

# Bootstrap with admin JWT if needed
if (-not $haveToken) {
  Write-Host "== Bootstrapping admin JWT (no actAs) =="
  $AdminToken   = New-AdminJwt -secret $JsonApiSecret -ledgerId $LedgerId `
    -participantId $ParticipantId -appId $AppId -lifetime $JwtLifetimeSecs
  $ADMIN_HEADERS = @{ Authorization = "Bearer $AdminToken"; "Content-Type"="application/json" }
  $null = JsonApi-GET $API_BASE $ADMIN_HEADERS "/v1/parties"

  # Ensure parties
  $OperatorId = Ensure-Party "Operator"          $API_BASE $ADMIN_HEADERS
  $Edge1Id    = Ensure-Party "EdgeNode1"        $API_BASE $ADMIN_HEADERS
  $Edge2Id    = Ensure-Party "EdgeNode2"        $API_BASE $ADMIN_HEADERS
  $SP1Id      = Ensure-Party "ServiceProvider1" $API_BASE $ADMIN_HEADERS
  $Dev1Id     = Ensure-Party "IoTDevice1"       $API_BASE $ADMIN_HEADERS
  $Dev2Id     = Ensure-Party "IoTDevice2"       $API_BASE $ADMIN_HEADERS
  $Dev3Id     = Ensure-Party "IoTDevice3"       $API_BASE $ADMIN_HEADERS

  # Mint Operator JWT
  Write-Host "== Minting Operator JWT =="
  $OP_TOKEN = New-OperatorJwt -secret $JsonApiSecret -ledgerId $LedgerId `
    -participantId $ParticipantId -appId $AppId -operatorId $OperatorId `
    -lifetime $JwtLifetimeSecs
  Set-Content -LiteralPath $OperatorTokenPath -Value $OP_TOKEN -NoNewline
  $OP_HEADERS = @{ Authorization = "Bearer $OP_TOKEN"; "Content-Type"="application/json" }
}

# Decode + print JWT claims
$claims = Decode-Jwt $OP_TOKEN
if (-not $claims) { throw "JWT parse failed. Is it a valid JWT?" }
$apiClaims = $claims.payload.'https://daml.com/ledger-api'
Write-Host "== JWT claims (decoded, unsigned) =="
Write-Host (" ledgerId       : {0}" -f $apiClaims.ledgerId)
Write-Host (" participantId  : {0}" -f $apiClaims.participantId)
Write-Host (" applicationId  : {0}" -f $apiClaims.applicationId)
Write-Host (" admin          : {0}" -f $apiClaims.admin)
Write-Host (" actAs          : {0}" -f (($apiClaims.actAs) -join ', '))

# Create admin headers from OP token if we didn't already create $ADMIN_HEADERS
if (-not $ADMIN_HEADERS) { $ADMIN_HEADERS = $OP_HEADERS }

# Resolve parties with Operator token (or admin token)
$OperatorId = Ensure-Party "Operator"          $API_BASE $ADMIN_HEADERS
$Edge1Id    = Ensure-Party "EdgeNode1"        $API_BASE $ADMIN_HEADERS
$Edge2Id    = Ensure-Party "EdgeNode2"        $API_BASE $ADMIN_HEADERS
$SP1Id      = Ensure-Party "ServiceProvider1" $API_BASE $ADMIN_HEADERS
$Dev1Id     = Ensure-Party "IoTDevice1"       $API_BASE $ADMIN_HEADERS
$Dev2Id     = Ensure-Party "IoTDevice2"       $API_BASE $ADMIN_HEADERS
$Dev3Id     = Ensure-Party "IoTDevice3"       $API_BASE $ADMIN_HEADERS

Write-Host "== Party identifiers =="
Write-Host (" Operator        : {0}" -f $OperatorId)
Write-Host (" EdgeNode1       : {0}" -f $Edge1Id)
Write-Host (" EdgeNode2       : {0}" -f $Edge2Id)
Write-Host (" ServiceProvider1: {0}" -f $SP1Id)
Write-Host (" IoTDevice1      : {0}" -f $Dev1Id)
Write-Host (" IoTDevice2      : {0}" -f $Dev2Id)
Write-Host (" IoTDevice3      : {0}" -f $Dev3Id)

# Ensure actAs includes Operator; if not, re-mint token
$act = @()
if ($apiClaims.actAs) { $act += $apiClaims.actAs }
elseif ($apiClaims.actas) { $act += $apiClaims.actas }
if (-not ($act -contains $OperatorId)) {
  Write-Warning "JWT actAs does not include resolved Operator. Re-minting..."
  $OP_TOKEN = New-OperatorJwt -secret $JsonApiSecret -ledgerId $LedgerId `
    -participantId $ParticipantId -appId $AppId -operatorId $OperatorId `
    -lifetime $JwtLifetimeSecs
  Set-Content -LiteralPath $OperatorTokenPath -Value $OP_TOKEN -NoNewline
  $OP_HEADERS = @{ Authorization = "Bearer $OP_TOKEN"; "Content-Type"="application/json" }
}

# --- FIX: Setup needs multi-party. So bootstrap is needed when RunSetup is true too. ---
$NeedBootstrap = $RunSetup -or $RunRunAll -or $RunSeedAbstractTimes -or $RunCalcMedian -or ($ExportPerfCsvPath -and $ExportPerfCsvPath.Trim())

function Ensure-BootstrapToken {
  param()
  if (Test-Path -LiteralPath $BootstrapTokenPath) { return }

  $AllActAs = @(
    $OperatorId, $Edge1Id, $Edge2Id, $SP1Id, $Dev1Id, $Dev2Id, $Dev3Id
  ) | Where-Object { $_ }

  if ($AllActAs.Count -lt 3) {
    throw "Party discovery failed (actAs too small): $($AllActAs -join ', ')"
  }

  $BOOT_TOKEN = New-MultiPartyJwt -secret $JsonApiSecret -ledgerId $LedgerId `
    -participantId $ParticipantId -appId $AppId -actAs $AllActAs `
    -lifetime $JwtLifetimeSecs

  Set-Content -LiteralPath $BootstrapTokenPath -Value $BOOT_TOKEN -NoNewline
}

if ($NeedBootstrap) {
  Ensure-BootstrapToken
  Write-Host "== bootstrap.jwt ready (needed for setup and/or multi-party scripts) =="
} else {
  Write-Host "== Skipping bootstrap.jwt mint (no setup/multi-party scripts requested) =="
}

# Discover package id
$dar = Get-NewestDar $DarPath
$PackageId = $null
if ($dar) { $PackageId = Get-PackageIdFromDar $dar.FullName }

try {
  $pkRaw = JsonApi-GET $API_BASE $OP_HEADERS "/v1/packages"
  $pkArr = Get-ResultArray $pkRaw
  Write-Host ("== JSON-API /v1/packages -> count: {0}" -f $pkArr.Count)
} catch {
  Write-Warning "Could not query /v1/packages: $($_.Exception.Message)"
}

if (-not $PackageId) { $PackageId = Discover-PackageIdViaApi $API_BASE $OP_HEADERS }

# If still no package id, upload/setup once (MUST use bootstrap token, not operator.jwt)
if (-not $PackageId) {
  if (-not $dar) { throw "Could not determine package id and no DAR found at '$DarPath'." }
  Ensure-BootstrapToken

  $LedgerHostForJsonApi = if ($LedgerHost -match '^[a-z]+://') { $LedgerHost } else { "http://$LedgerHost" }
  Write-Host "Package id not found. Running Main:setup once to upload DAR (bootstrap token)..."
  & daml script --dar "$($dar.FullName)" --script-name "Main:setup" --json-api `
    --ledger-host "$LedgerHostForJsonApi" --ledger-port $LedgerHttpPort `
    --access-token-file (Resolve-Path $BootstrapTokenPath).Path

  if ($LASTEXITCODE -ne 0) { throw ("daml script Main:setup (bootstrap) failed ({0})" -f $LASTEXITCODE) }
  Start-Sleep -Seconds 1
  $PackageId = Discover-PackageIdViaApi $API_BASE $OP_HEADERS
}

if (-not $PackageId) { throw "Could not determine package id." }
Write-Host ("Using DAML_PKG_ID = {0}" -f $PackageId)

# ── template IDs for inventory ─────
$T = @{
  TACommittee      = "{0}:Main:TACommittee"      -f $PackageId
  TaSnapshot       = "{0}:Main:TaSnapshot"       -f $PackageId
  SnapshotProposal = "{0}:Main:SnapshotProposal" -f $PackageId
  SnapshotApproval = "{0}:Main:SnapshotApproval" -f $PackageId
  SigAttestation   = "{0}:Main:SigAttestation"   -f $PackageId
  RevokedKey       = "{0}:Main:RevokedKey"       -f $PackageId
  SPProfile        = "{0}:Main:SPProfile"        -f $PackageId
  AccessPolicy     = "{0}:Main:AccessPolicy"     -f $PackageId
  Device           = "{0}:Main:Device"           -f $PackageId
  BrokerContract   = "{0}:Main:BrokerContract"   -f $PackageId
  RelayLog         = "{0}:Main:RelayLog"         -f $PackageId
  LogRequest       = "{0}:Main:LogRequest"       -f $PackageId
  RatchetState     = "{0}:Main:RatchetState"     -f $PackageId
}
$Global:TaThreshold = $null
$Global:TaMembers   = @()

# Run Main:setup (idempotent)  ✅ FIX: USE BOOTSTRAP TOKEN
if ($RunSetup) {
  if (-not $dar) { throw "Cannot run setup: DAR not found at $DarPath" }
  Ensure-BootstrapToken
  $LedgerHostForJsonApi = if ($LedgerHost -match '^[a-z]+://') { $LedgerHost } else { "http://$LedgerHost" }

  Write-Host "== Running daml script Main:setup over JSON-API (bootstrap token) =="
  & daml script --dar "$($dar.FullName)" --script-name "Main:setup" --json-api `
    --ledger-host "$LedgerHostForJsonApi" --ledger-port $LedgerHttpPort `
    --access-token-file (Resolve-Path $BootstrapTokenPath).Path

  if ($LASTEXITCODE -ne 0) { throw ("daml script Main:setup failed ({0})" -f $LASTEXITCODE) }
}

# Run RunAll:runAll (tolerant to duplicate key)
if ($RunRunAll) {
  if (-not $dar) { throw "Cannot run RunAll: DAR not found at $DarPath" }
  if (-not (Test-Path -LiteralPath $BootstrapTokenPath)) {
    throw "RunRunAll requested but bootstrap token is missing. Re-run with -RunSetup or enable bootstrap."
  }
  $LedgerHostForJsonApi = if ($LedgerHost -match '^[a-z]+://') { $LedgerHost } else { "http://$LedgerHost" }
  Write-Host "== Running daml script RunAll:runAll (multi-party token) =="
  try {
    & daml script --dar "$($dar.FullName)" --script-name "RunAll:runAll" --json-api `
      --ledger-host "$LedgerHostForJsonApi" --ledger-port $LedgerHttpPort `
      --access-token-file (Resolve-Path $BootstrapTokenPath).Path
    if ($LASTEXITCODE -ne 0) { throw ("daml script RunAll:runAll failed ({0})" -f $LASTEXITCODE) }
  } catch {
    $msg = "$($_.Exception.Message)"
    if ($msg -match 'ALREADY_EXISTS: DUPLICATE_CONTRACT_KEY') {
      Write-Warning "RunAll hit DUPLICATE_CONTRACT_KEY (attestation already exists). Continuing…"
    } else { throw }
  }
}

# Optional extras (perf / median)
if ($RunSeedAbstractTimes) {
  if (-not $dar) { throw "Cannot seed abstract times: DAR not found at $DarPath" }
  if (-not (Test-Path -LiteralPath $BootstrapTokenPath)) { throw "seedAbstractTimes requires bootstrap token." }
  $LedgerHostForJsonApi = if ($LedgerHost -match '^[a-z]+://') { $LedgerHost } else { "http://$LedgerHost" }
  Write-Host "== Running RunAll:seedAbstractTimes =="
  & daml script --dar "$($dar.FullName)" --script-name "RunAll:seedAbstractTimes" --json-api `
    --ledger-host "$LedgerHostForJsonApi" --ledger-port $LedgerHttpPort `
    --access-token-file (Resolve-Path $BootstrapTokenPath).Path
}

if ($RunCalcMedian) {
  if (-not $dar) { throw "Cannot calc median: DAR not found at $DarPath" }
  if (-not (Test-Path -LiteralPath $BootstrapTokenPath)) { throw "calcMedian requires bootstrap token." }
  $LedgerHostForJsonApi = if ($LedgerHost -match '^[a-z]+://') { $LedgerHost } else { "http://$LedgerHost" }
  Write-Host "== Running RunAll:calcMedian =="
  & daml script --dar "$($dar.FullName)" --script-name "RunAll:calcMedian" --json-api `
    --ledger-host "$LedgerHostForJsonApi" --ledger-port $LedgerHttpPort `
    --access-token-file (Resolve-Path $BootstrapTokenPath).Path
}

if ($ExportPerfCsvPath -and $ExportPerfCsvPath.Trim()) {
  if (-not $dar) { throw "Cannot export CSV: DAR not found at '$DarPath'" }
  if (-not (Test-Path -LiteralPath $BootstrapTokenPath)) { throw "exportPerfCSV requires bootstrap token." }
  $LedgerHostForJsonApi = if ($LedgerHost -match '^[a-z]+://') { $LedgerHost } else { "http://$LedgerHost" }

  Write-Host ("== Exporting perf CSV to {0} ==" -f $ExportPerfCsvPath)

  $csvRaw = & daml script --dar "$($dar.FullName)" --script-name "RunAll:exportPerfCSV" --json-api `
    --ledger-host "$LedgerHostForJsonApi" --ledger-port $LedgerHttpPort `
    --access-token-file (Resolve-Path $BootstrapTokenPath).Path

  $csv = @()
  $inCsv = $false

  foreach ($line in $csvRaw) {
    if (-not $inCsv -and $line -match 'operation,tag,ms,timestamp') {
      $inCsv = $true; $csv += 'operation,tag,ms,timestamp'; continue
    }
    if ($inCsv) {
      if ($line -match '^[A-Za-z0-9_.:-]+,[A-Za-z0-9_.:-]+,[0-9]+,') { $csv += $line }
    }
  }

  if ($csv.Count -eq 0) {
    Write-Warning "No perf data found in RunAll:exportPerfCSV output (only logs or no measurements)."
  } else {
    $csv | Out-File -FilePath $ExportPerfCsvPath -Encoding ascii
    Write-Host ("Wrote {0} rows to {1}" -f $csv.Count, $ExportPerfCsvPath)
  }
}

# ── start (or connect to) Flask wired to Operator & this package id ─────────
Remove-Item Env:DAML_PARTY     -ErrorAction SilentlyContinue
Remove-Item Env:DAML_PKG_PARTY -ErrorAction SilentlyContinue

$LedgerHostForFlask = $LedgerHost
if ($FlaskMode -eq "Wsl" -and ($LedgerHost -in @("localhost","127.0.0.1"))) {
  $winIp = Get-WindowsHostIpForWsl
  if ($winIp) {
    Write-Host ("WSL Flask: mapping LEDGER_HOST localhost -> {0}" -f $winIp)
    $LedgerHostForFlask = $winIp
  } else {
    Write-Warning "WSL Flask: could not auto-detect Windows host IP. LEDGER_HOST may be wrong."
  }
}

$env:DAML_PKG_ID      = $PackageId
$env:LEDGER_HOST      = $LedgerHostForFlask
$env:LEDGER_HTTP_PORT = [string]$LedgerHttpPort
$env:TOKEN_PATH       = (Resolve-Path $OperatorTokenPath).Path
$env:FLASK_PORT       = [string]$FlaskPort

$flaskProc = $null

if ($FlaskMode -eq "Windows" -and $StartFlask) {
  Kill-ProcessOnPort -port $FlaskPort
  Write-Host "== Starting Flask on Windows Python (py -3) =="
  $flaskProc = Start-Process -FilePath "py" -ArgumentList "-3","flask_app.py" -WorkingDirectory $scriptDir -PassThru
}
elseif ($FlaskMode -eq "Wsl" -and $StartFlask) {
  Kill-ProcessOnPort -port $FlaskPort
  Write-Host "== Starting Flask inside WSL (micromamba scope-oqs) =="
  $wslDir = Convert-PathToWsl $scriptDir
  $tokWsl = Convert-PathToWsl (Resolve-Path $OperatorTokenPath)
  $cmd = @"
source ~/.bashrc
micromamba activate scope-oqs
export DAML_PKG_ID='$PackageId'
export LEDGER_HOST='$LedgerHostForFlask'
export LEDGER_HTTP_PORT='$LedgerHttpPort'
export FLASK_PORT='$FlaskPort'
export TOKEN_PATH='$tokWsl'
cd '$wslDir'
python flask_app.py
"@
  $flaskProc = Start-Process -FilePath "wsl.exe" -ArgumentList @("bash","-lc",$cmd) -PassThru
}

if ($FlaskMode -ne "External" -and $StartFlask) {
  for ($i=0; $i -lt 60; $i++) {
    if (Flask-Ready) { break }
    Start-Sleep -Milliseconds 500
  }
  if (-not (Flask-Ready)) {
    throw ("Flask did not become ready on {0}:{1}." -f $FlaskHost, $FlaskPort)
  }
}

Write-Host "== Flask health: /health/keys =="
if (-not (Flask-Ready)) {
  throw ("Cannot reach Flask at {0}:{1}. If running in WSL, start it with -FlaskMode Wsl -StartFlask or keep -FlaskMode External when it's already running." -f $FlaskHost, $FlaskPort)
}
$health = Invoke-RestMethod -Uri (Url-Flask "/health/keys") -TimeoutSec 10
$health | ConvertTo-Json -Depth $Global:JSON_DEPTH

# Pick KEM + PQ sig algorithm from /health/keys
$kem = $null
if ($health.enabled_kems -and $health.enabled_kems -contains "ML-KEM-768") {
  $kem = "ML-KEM-768"
} elseif ($health.enabled_kems -and $health.enabled_kems -contains "Kyber768") {
  $kem = "Kyber768"
} elseif ($health.enabled_kems -and $health.enabled_kems.Count -gt 0) {
  $kem = $health.enabled_kems[0]
} else {
  $kem = "ML-KEM-768"
}

$sigAlg = $null
if ($health.demo -and $health.demo.alg) {
  $sigAlg = $health.demo.alg
} elseif ($health.enabled_sigs -and $health.enabled_sigs.Count -gt 0) {
  $sigAlg = $health.enabled_sigs[0]
} else {
  $sigAlg = "ML-DSA-65"
}

Write-Host "== QUICK TEST: /crypto/prepare_hybrid minimal payload =="
if ($health -and $health.has_oqs -eq $true) {
  try {
    $resDevTest = JsonQuery -apiBase $API_BASE -headers $OP_HEADERS -tids @($T.Device)
    if (-not $resDevTest.result -or $resDevTest.result.Count -eq 0) {
      throw "No Device contracts found for minimal test."
    }
    $devRowTest    = $resDevTest.result | Where-Object { $_.payload.name -eq $TargetDeviceDisplay } | Select-Object -First 1
    if (-not $devRowTest) { $devRowTest = $resDevTest.result[0] }
    $DeviceX25519_Test = $devRowTest.payload.publicKey

    $minimalBody = @{
      kem                   = $kem
      alg                   = "ed25519"
      sig_alg               = "ed25519"
      device_public_key_hex = $DeviceX25519_Test
      plaintext             = "hello-minimal"
      plaintext_is_b64      = $false
      aad                   = "aad-minimal"
      ctx                   = @{ purpose = "minimal-test" }
      epoch                 = 0
    }
    if ($DeviceKyberPubB64) { $minimalBody.device_pq_pub_b64 = $DeviceKyberPubB64 }

    $testResp = Invoke-PostJson (Url-Flask "/crypto/prepare_hybrid") $minimalBody
    Write-Host "  Minimal /crypto/prepare_hybrid -> OK"
    $testResp | ConvertTo-Json -Depth $Global:JSON_DEPTH
  } catch {
    Write-Warning ("  Minimal /crypto/prepare_hybrid FAILED: {0}" -f $_.Exception.Message)
  }
} else {
  Write-Host ("  Skipping minimal /crypto/prepare_hybrid: has_oqs={0}" -f $health.has_oqs)
}

# ── PQ demo ────────────────────────────────────────────────────────────────
if ($RunPQDemo -and $health -and $health.has_oqs -and $health.has_oqs -eq $true) {
  try {
    $pqAlg = $null
    if ($health.demo -and $health.demo.alg) { $pqAlg = $health.demo.alg }
    elseif ($health.enabled_sigs -and $health.enabled_sigs.Count -gt 0) { $pqAlg = $health.enabled_sigs[0] }

    if ($pqAlg) {
      Write-Host ("== PQ demo using alg: {0} ==" -f $pqAlg)
      $msg = "U0NPUEUgUFEgZGVtbyBmcm9tIFBvd2VyU2hlbGw="
      $signResp = Invoke-PostJson (Url-Flask "/pq/sign") @{
        alg     = $pqAlg
        message = $msg
      }
      $pub = $signResp.public_key_b64u
      $sig = $signResp.signature_b64u

      $verResp = Invoke-PostJson (Url-Flask "/pq/verify") @{
        alg       = $pqAlg
        message   = $msg
        signature = $sig
        public_key= $pub
      }
      Write-Host ("   verify.valid = {0}" -f $verResp.valid)
    } else {
      Write-Host "liboqs present but no signature algs reported."
    }
  } catch {
    Write-Warning ("PQ demo failed: {0}" -f $_.Exception.Message)
  }
}

Write-Host "== Create small LogRequest via Flask =="
$demo = @{
  logs = @(@{
    op="ping"; msg="hello from ps test";
    ts=[int][DateTimeOffset]::UtcNow.ToUnixTimeSeconds()
  })
} | ConvertTo-Json -Depth $Global:JSON_DEPTH -Compress

Invoke-RestMethod -Method Post -Uri (Url-Flask "/log_batch_activity") `
  -ContentType "application/json" -Body $demo | ConvertTo-Json -Depth $Global:JSON_DEPTH

Write-Host "== Active contracts (Operator's view) =="
foreach ($kv in $T.GetEnumerator() | Sort-Object Name) {
  $tid = $kv.Value
  try {
    $res = JsonQuery -apiBase $API_BASE -headers $OP_HEADERS -tids @($tid)
    $rows = @()
    if ($res -and $res.result) { $rows = $res.result }
    $n = ($rows | Measure-Object).Count
    Write-Host ("  {0,-18} : {1,3} active" -f $kv.Key, $n)
  } catch {
    Write-Warning ("  {0,-18} : query failed: {1}" -f $kv.Key, $_.Exception.Message)
  }
}

Write-Host "== Devices (owner, broker, name, publicKey) =="
try {
  $resD = JsonQuery -apiBase $API_BASE -headers $OP_HEADERS -tids @($T.Device)
  foreach ($r in $resD.result) {
    $p = $r.payload
    Write-Host ("  {0}  owner={1}  broker={2}  name={3}  pk={4}" -f `
      $r.contractId, $p.owner, $p.broker, $p.name, $p.publicKey)
  }
} catch { Write-Warning $_ }

Write-Host "== BrokerContract edgeNodes & iotDevices =="
try {
  $resB = JsonQuery -apiBase $API_BASE -headers $OP_HEADERS -tids @($T.BrokerContract)
  foreach ($r in $resB.result) {
    $p = $r.payload
    $edges   = ($p.edgeNodes  | ForEach-Object { Pair1 $_ }) -join ", "
    $devices = ($p.iotDevices | ForEach-Object { "{0}:{1}" -f (Pair1 $_),(Pair2 $_) }) -join ", "
