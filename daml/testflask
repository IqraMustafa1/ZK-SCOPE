function Invoke-PostJson([string]$uri, [hashtable]$obj) {
  $body = $obj | ConvertTo-Json -Depth $Global:JSON_DEPTH -Compress
  try {
    Invoke-RestMethod -Method Post -Uri $uri -ContentType "application/json" -Body $body -TimeoutSec 60
  } catch {
    $resp = $_.Exception.Response
    $txt = $null
    if ($resp) { try { $sr = New-Object System.IO.StreamReader($resp.GetResponseStream()); $txt = $sr.ReadToEnd() } catch {} }
    if (-not $txt) { $txt = "(no response body)" }
    throw ("POST {0} failed: {1}`n{2}" -f $uri, $_.Exception.Message, $txt)
  }
}
function Invoke-PostJson-WithHeaders([string]$uri, [hashtable]$obj, [hashtable]$headers) {
  $body = $obj | ConvertTo-Json -Depth $Global:JSON_DEPTH -Compress
  try {
    Invoke-RestMethod -Method Post -Uri $uri -Headers $headers -ContentType "application/json" -Body $body -TimeoutSec 60
  } catch {
    $resp = $_.Exception.Response
    $txt = $null
    if ($resp) { try { $sr = New-Object System.IO.StreamReader($resp.GetResponseStream()); $txt = $sr.ReadToEnd() } catch {} }
    if (-not $txt) { $txt = "(no response body)" }
    throw ("POST {0} failed: {1}`n{2}" -f $uri, $_.Exception.Message, $txt)
  }
}

function Invoke-PostJson-Tolerant([string]$uri, [hashtable]$primary, [hashtable[]]$alternates=@()) {
  $attempts = @()
  $attempts += @{ name = "primary"; body = $primary }

  foreach ($alt in $alternates) {
    $nm = if ($alt.ContainsKey('_name')) { $alt['_name'] } else { "alternate" }
    $attempts += @{ name = $nm; body = $alt }
  }

  $errors = @()
  foreach ($a in $attempts) {
    $nm = $a.name
    $bodyClean = @{}
    foreach ($k in $a.body.Keys) { if ($k -ne "_name") { $bodyClean[$k] = $a.body[$k] } }
    try {
      $resp = Invoke-PostJson -uri $uri -obj $bodyClean
      return @{ ok=$true; variant=$nm; resp=$resp; body=$bodyClean }
    } catch {
      $errors += ("[{0}] {1}" -f $nm, $_.Exception.Message)
    }
  }
  throw ("All variants failed for {0}:`n{1}" -f $uri, ($errors -join "`n"))
}

