function Poll-LatestRelayCid {
  param([int]$tries = 20, [int]$sleepMs = 300)
  $relayCid = $null
  for ($i=0; $i -lt $tries -and -not $relayCid; $i++) {
    try {
      $list = Invoke-RestMethod -Uri (Url-Flask "/relay/list") -TimeoutSec 5
      $items = @()
      if ($list -and $list.PSObject.Properties.Match('items').Count -gt 0) { $items = @($list.items) }
      if ($items.Count -gt 0) {
        $relayCid = ($items | Sort-Object { $_.payload.ts } -Descending | Select-Object -First 1).contractId
        if ($relayCid) { break }
      }
    } catch {}

    try {
      $resRL = JsonQuery -apiBase $API_BASE -headers $OP_HEADERS -tids @($T.RelayLog)
      if ($resRL.result -and $resRL.result.Count -gt 0) {
        $relayCid = ($resRL.result | Sort-Object { $_.payload.ts } -Descending | Select-Object -First 1).contractId
        if ($relayCid) { break }
      }
    } catch {}

    try {
      $lv = Invoke-RestMethod -Uri (Url-Flask "/debug/last_verify") -TimeoutSec 3
      if ($lv -and $lv.relaylog_cid) { $relayCid = $lv.relaylog_cid; break }
    } catch {}

    Start-Sleep -Milliseconds $sleepMs
  }
  return $relayCid
}

# === HYBRID RELAY (keys + sign) ============================================
if ($RunHybridRelay) {
  if (-not $health -or -not $health.has_oqs) {
    throw "Hybrid relay requires python-oqs on Flask side. /health/keys reported has_oqs=$($health.has_oqs)."
  }

  $DeviceKyberPubB64u = $null
  if ($DeviceKyberPubB64 -and $DeviceKyberPubB64.Trim()) {
    $DeviceKyberPubB64u = $DeviceKyberPubB64.Trim().TrimEnd('=').Replace('+','-').Replace('/','_')
  }

  $EdgeId = Ensure-Party $EdgePartyDisplay $API_BASE $ADMIN_HEADERS
  $SPId   = Ensure-Party $ServiceProviderDisplay $API_BASE $ADMIN_HEADERS

  $resDev = JsonQuery -apiBase $API_BASE -headers $OP_HEADERS -tids @($T.Device)
  if (-not $resDev.result -or $resDev.result.Count -eq 0) { throw "No Device contracts found." }
  $devRow = $resDev.result | Where-Object { $_.payload.name -eq $TargetDeviceDisplay } | Select-Object -First 1
  if (-not $devRow) { throw ("TargetDeviceDisplay '{0}' not found among Device contracts." -f $TargetDeviceDisplay) }

  $DeviceCid    = $devRow.contractId
  $DeviceX25519 = $devRow.payload.publicKey
  $DeviceOwner  = $devRow.payload.owner

  try { $CtxObj = $CtxJson | ConvertFrom-Json } catch { throw "CtxJson is not valid JSON: $CtxJson" }

  $MsgTs = ([DateTime]::UtcNow.ToString("yyyy-MM-ddTHH:mm:ssZ"))

  $EdgeToken = New-MultiPartyJwt -secret $JsonApiSecret -ledgerId $LedgerId `
    -participantId $ParticipantId -appId $AppId -actAs @($EdgeId, $OperatorId) `
    -lifetime $JwtLifetimeSecs

  $EffectiveEpoch = if ($Epoch -lt 0) {
    Get-LatestEpoch -apiBase $API_BASE -headers $OP_HEADERS -tidTaSnapshot $T.TaSnapshot
  } else { [int]$Epoch }

  Write-Host ("Using epoch = {0}" -f $EffectiveEpoch)

  # --- FIX: ledger-derived ratchet counter MUST be used ---
  $SenderId = "Sender1"   # MUST match relayBody.senderId below
  $nextCtr  = Get-NextRatchetCounter -apiBase $API_BASE -headers $OP_HEADERS `
    -tidRatchetState $T.RatchetState -edge $EdgeId -deviceKey $DeviceX25519 `
    -senderId $SenderId -epoch $EffectiveEpoch

  $hybridSigAlg = "ed25519"
  Write-Host ("Preparing hybrid message with enforced counter={0}" -f $nextCtr)

  # 1) Prepare hybrid WITH enforced counter (digest must bind to this)
  $prepTry = Prepare-Hybrid-EnforceCounter `
    -ctrToUse $nextCtr -epochToUse $EffectiveEpoch -deviceX25519 $DeviceX25519 `
    -ctxObj $CtxObj -aadPlain $AAD -ptPlain $Plaintext `
    -kemAlg $kem -sigAlg $hybridSigAlg `
    -deviceKyberPubB64 $DeviceKyberPubB64 -deviceKyberPubB64u $DeviceKyberPubB64u

  Write-Host ("== /crypto/prepare_hybrid accepted variant: {0} ==" -f $prepTry.variant)
  $prep = $prepTry.resp

  $encB64  = _getField $prep @('encryptedMessage_b64','encrypted_message_b64','ciphertext_b64','ciphertext_b64u')
  $digest  = _getField $prep @('digest_hex','digestHex','digest')
  $ephX    = _getField $prep @('ephemeral_x25519_hex','eph_x25519_hex','ephX25519Hex')
  $counterFromPrep = _getField $prep @('counter','ctr')

  $kyberCT = _getField $prep @('kyberCiphertextB64','kyber_ciphertext_b64','kyber_ciphertext_b64u')
  $pqSig   = _getField $prep @('pqSignatureB64','pq_signature_b64','pq_signature_b64u')
  $pqPub   = _getField $prep @('pqPubKey','pq_pub_key_b64','pq_pub_b64','device_pq_pub_b64','device_pq_pub_b64u')

  if (-not $encB64 -or -not $digest -or -not $ephX -or -not $kyberCT -or -not $pqSig -or -not $pqPub) {
    throw "prepare_hybrid response missing fields. Got keys: $($prep.PSObject.Properties.Name -join ', ')"
  }

  # enforce counter consistency
  $ctrToUse = [int]$nextCtr
  if ($counterFromPrep -ne $null) {
    $cprep = [int]$counterFromPrep
    if ($cprep -ne $ctrToUse) {
      throw ("prepare_hybrid returned counter={0} but ledger requires {1}. Fix Flask to accept 'counter/ctr' input or schema mismatch." -f $cprep, $ctrToUse)
    }
  }

  # SP signs digest
  $sigResp = Invoke-PostJson (Url-Flask "/sp/ed25519/sign_digest") @{ digest_hex = $digest }
  $spPubHex = $sigResp.sp_ed25519_pub_hex
  $spSigB64 = $sigResp.sp_signature_b64
  if (-not $spPubHex -or -not $spSigB64) { throw "SP Ed25519 signing failed." }

  # Determine needed attestations
  $hybridTag  = "ALG_HYBRID_X25519_KYBER_AESGCM_HYBRID_SIG"
  $threshold = if ($Global:TaThreshold -ne $null) { [int]$Global:TaThreshold } else { 0 }
  $needed = if ($threshold -gt 0) { $threshold } else { [int]$AttestationCount }
  if ($needed -lt 1) { $needed = 1 }

  # Issuers: prefer TACommittee.members if present
  $issuers = @()
  if ($Global:TaMembers -and $Global:TaMembers.Count -gt 0) {
    $issuers = @($Global:TaMembers | Where-Object { $_ } | Select-Object -Unique)
  } else {
    $issuers = @($Edge1Id, $Edge2Id) | Where-Object { $_ } | Select-Object -Unique
  }

  if ($issuers.Count -lt $needed) {
    if ($threshold -gt 0) {
      throw ("Hybrid relay: threshold={0} but only {1} TACommittee member(s) available in script context." -f $needed, $issuers.Count)
    }
    Write-Warning ("Hybrid relay: need {0} attestations but only {1} issuer(s) available; using available." -f $needed, $issuers.Count)
    $needed = $issuers.Count
  }
  if ($needed -lt 1) { throw "Hybrid relay: no issuers available for SigAttestation." }

  # 1) Reuse existing CURRENT-digest attestations
  $attCids = @()
  try {
    $hits = Find-SigAttestationCidsForDigest -apiBase $API_BASE -headers $OP_HEADERS `
      -tid $T.SigAttestation -digest $digest -deviceOwner $DeviceOwner -devicePublicKey $DeviceX25519 `
      -operator $OperatorId -algId $hybridTag

    if ($hits -and $hits.Count -gt 0) {
      $hits2 = $hits | Where-Object { $issuers -contains $_.payload.issuer }
      if (-not $hits2 -or $hits2.Count -eq 0) { $hits2 = $hits }
      $attCids = @($hits2 | Select-Object -First $needed | ForEach-Object { $_.contractId })
    }
  } catch {
    Write-Warning ("SigAttestation digest query failed (will try create): {0}" -f $_.Exception.Message)
  }

  # 2) Create missing attestations for THIS digest
  if ($attCids.Count -lt $needed) {
    $attestToken = New-MultiPartyJwt -secret $JsonApiSecret -ledgerId $LedgerId -participantId $ParticipantId -appId $AppId `
      -actAs (@($OperatorId) + $issuers) -lifetime $JwtLifetimeSecs
    $ATTEST_HEADERS = @{ Authorization = "Bearer $attestToken"; "Content-Type"="application/json" }

    $attCids = @()
    for ($i=0; $i -lt $needed; $i++) {
      $issuer = $issuers[$i]
      $cid = Ensure-SigAttestationForDigest -apiBase $API_BASE -attestHeaders $ATTEST_HEADERS `
        -tid $T.SigAttestation -issuer $issuer -digest $digest `
        -deviceOwner $DeviceOwner -devicePublicKey $DeviceX25519 `
        -operator $OperatorId -algId $hybridTag -senderPublicKey $spPubHex
      $attCids += $cid
    }
  }

  if ($attCids.Count -lt 1) {
    throw "Hybrid relay: no CURRENT-digest attestations available/created; refusing to call relay_message."
  }
  if ($threshold -gt 0 -and $attCids.Count -lt $threshold) {
    throw ("Hybrid relay: threshold={0} but only {1} CURRENT-digest attestations were obtained." -f $threshold, $attCids.Count)
  }

  Write-Host "Attestations (CURRENT digest) contractIds:"
  $attCids | ForEach-Object { Write-Host "  $_" }

  # ZK
  $useZk = [bool]$UseZkPac
  if ($useZk -and -not $PolicyId) { throw "UseZkPac=true requires -PolicyId." }

  $mr = Get-MerkleRootForEpoch -apiBase $API_BASE -headers $OP_HEADERS -tidTaSnapshot $T.TaSnapshot -epoch $EffectiveEpoch

  # Build relay payload (NO nulls)
  $relayBody = [ordered]@{
    algId_tag            = $hybridTag

    edge_token           = $EdgeToken
    edge                 = $EdgeId
    sp                   = $SPId
    senderId             = "Sender1"
    targetDevice         = $DeviceCid

    epoch                = [int]$EffectiveEpoch
    msgTimestamp         = $MsgTs
    merkleRoot           = $mr

    use_zkpac            = $useZk

    attestation_cids     = @($attCids)
    attestations         = @($attCids)

    encryptedMessage_b64 = $encB64
    digest_hex           = $digest
    digest               = $digest

    devicePublicKey      = $DeviceX25519
    ephemeral_x25519_hex = $ephX
    aad                  = $AAD
    counter              = [int]$ctrToUse   # ✅ ledger-derived

    sp_ed25519_pub_hex   = $spPubHex
    sp_signature_b64     = $spSigB64

    kyberCiphertextB64   = $kyberCT
    pqSignatureB64       = $pqSig
    pqPubKey             = $pqPub
  }

  if ($useZk) {
    $relayBody["policy_proof"] = @{ policyId=$PolicyId; leafHash=""; merklePath=@(); revealedAttrs=@() }
  }

  $payloadPath = Join-Path $scriptDir "last_relay_payload.json"
  ($relayBody | ConvertTo-Json -Depth $Global:JSON_DEPTH) | Set-Content -Encoding UTF8 -Path $payloadPath
  Write-Host ("Saved relay payload -> {0}" -f $payloadPath)

  $relayResp = $null
  $relayPaths = @("/relay_message", "/relay/message")
  $relayErrors = @()

  foreach ($path in $relayPaths) {
    $uri = Url-Flask $path
    try {
      $relayResp = Invoke-PostJson -uri $uri -obj $relayBody
      Write-Host ("== relay_message (hybrid) OK via {0} ==" -f $path)
      break
    } catch {
      $relayErrors += ("  {0} -> {1}" -f $path, $_.Exception.Message)
    }
  }

  if (-not $relayResp) {
    throw ("relay_message failed for all paths:`n{0}" -f ($relayErrors -join "`n"))
  }

  ($relayResp | ConvertTo-Json -Depth $Global:JSON_DEPTH)
}

# Ack newest RelayLog as IoTDevice1
# Ack newest RelayLog (on-ledger) using Operator token
if ($AckLatestRelay) {
  Write-Host "== Acknowledging latest RelayLog (using Operator JWT) =="

  $relayCid = Poll-LatestRelayCid
  if (-not $relayCid) {
    Write-Warning "No RelayLog found to acknowledge."
  } else {
    Write-Host ("  Acknowledging RelayLog CID: {0}" -f $relayCid)

    # IMPORTANT:
    # Acknowledge choice is controlled by Operator/Edge (NOT IoTDevice),
    # so we use Operator token here.
    $ackHeaders = @{ Authorization = "Bearer $OP_TOKEN" }

    $acked = $false
    $newCid = $null

    # 1) Preferred: ack the specific CID we found
    try {
      $res = Invoke-PostJson-WithHeaders (Url-Flask "/relay/ack") @{
        relayLogCid = $relayCid   # ✅ new Flask expects relayLogCid/contractId/cid
      } $ackHeaders

      Write-Host "  /relay/ack -> OK"
      $acked = $true

      # If Flask returns new_cid, capture it (ack typically archives+recreates)
      if ($res -and ($res.PSObject.Properties.Match('new_cid').Count -gt 0)) {
        $newCid = $res.new_cid
      }
      if ($newCid) {
        Write-Host ("  Acked RelayLog new CID: {0}" -f $newCid)
      }
    } catch {
      Write-Warning ("  /relay/ack failed -> {0}" -f $_.Exception.Message)
    }

    # 2) Fallback: ask Flask to find and ack the latest unacked
    if (-not $acked) {
      try {
        $res = Invoke-PostJson-WithHeaders (Url-Flask "/relay/ack_latest") @{
          # optional filters (safe to send even if Flask ignores them)
          epoch    = 0
          senderId = "Sender1"
        } $ackHeaders

        Write-Host "  /relay/ack_latest -> OK"
        $acked = $true

        if ($res -and ($res.PSObject.Properties.Match('new_cid').Count -gt 0)) {
          $newCid = $res.new_cid
        }
        if ($newCid) {
          Write-Host ("  Acked RelayLog new CID: {0}" -f $newCid)
        }
      } catch {
        Write-Warning ("  /relay/ack_latest failed -> {0}" -f $_.Exception.Message)
      }
    }

    if ($acked) { Write-Host "  Ack succeeded." } else { Write-Warning "Ack did not succeed via any path." }
  }
}


