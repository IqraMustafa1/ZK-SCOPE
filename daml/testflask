  [string]$DarPath            = ".\.daml\dist\*.dar",

  # Flask connectivity
  [string]$FlaskHost          = "localhost",
  [int]   $FlaskPort          = 5000,
  [ValidateSet("Windows","Wsl","External")]
  [string]$FlaskMode          = "External",  # default: do not start Flask automatically
  [switch]$StartFlask         = $true,       # honored only when FlaskMode=Windows or Wsl
  [switch]$KillFlaskAtEnd     = $false,      # stop Flask when done (Windows/Wsl modes)

  # DAML scripts toggles
  [switch]$RunSetup           = $true,     # daml script Main:setup
  [switch]$RunRunAll          = $false,    # daml script RunAll:runAll (multi-party)
  [switch]$AckLatestRelay     = $true,     # mint IoTDevice1 JWT and ack newest relay

  # extras (perf / median)
  [switch]$RunSeedAbstractTimes = $false,  # daml script RunAll:seedAbstractTimes
  [switch]$RunCalcMedian        = $false,  # daml script RunAll:calcMedian
  [string]$ExportPerfCsvPath    = "",      # daml script RunAll:exportPerfCSV -> file path

  # PQ demo
  [switch]$RunPQDemo          = $true,

  # === keys + sign + hybrid relay path ===
  [switch]$RunHybridRelay     = $true,
  [string]$EdgePartyDisplay   = "EdgeNode1",
  [string]$ServiceProviderDisplay = "ServiceProvider1",
  [string]$TargetDeviceDisplay    = "Device1",  # match Device.payload.name
  [int]   $Epoch              = -1,
  [string]$Plaintext          = "hello hybrid from PowerShell",
  [string]$AAD                = "ps-aad",
  [string]$CtxJson            = '{"purpose":"relay-demo"}',
  [string]$DeviceKyberPubB64  = "",
  [switch]$UseZkPac           = $false,
  [string]$PolicyId           = "",
  [int]   $AttestationCount   = 2,

  # JWT/JSON-API auth parameters
  [string]$JsonApiSecret      = "secret",
  [string]$LedgerId           = "local",
  [string]$ParticipantId      = "local",
  [string]$AppId              = "scope-app",
  [int]   $JwtLifetimeSecs    = 86400
)

$ErrorActionPreference = "Stop"

