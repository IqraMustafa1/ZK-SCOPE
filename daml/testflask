function NewPartyJwt { param([string]$party,[int]$lifetime=3600)
  New-PartyJwt -secret $JsonApiSecret -ledgerId $LedgerId -participantId $ParticipantId -appId $AppId -party $party -lifetime $lifetime
}

function Decode-Base64Url([string]$s) {
  $p = $s.Replace("-","+").Replace("_","/")
  while ($p.Length % 4) { $p += "=" }
  [System.Text.Encoding]::UTF8.GetString([Convert]::FromBase64String($p))
}
function Decode-Jwt([string]$token) {
  try {
    $parts = $token -split "\."
    if ($parts.Length -lt 2) { return $null }
    $hdr = Decode-Base64Url $parts[0] | ConvertFrom-Json
    $pl  = Decode-Base64Url $parts[1] | ConvertFrom-Json
    [pscustomobject]@{ header=$hdr; payload=$pl }
  } catch { $null }
}

function JsonQuery([string]$apiBase, $headers, [string[]]$tids) {
  JsonApi-POST $apiBase $headers "/v1/query" @{
    templateIds = $tids; query = @{}
  }
}

function Parties-List($apiBase, $headers) {
  JsonApi-GET $apiBase $headers "/v1/parties"
}
function Ensure-Party([string]$display, $apiBase, $headers) {
  $plist = Parties-List $apiBase $headers
  $rows = Get-ResultArray $plist
  $hit = $rows | Where-Object { $_.displayName -eq $display } | Select-Object -First 1
  if ($hit) { return $hit.identifier }
  Write-Host ("Allocating party displayName='{0}' ..." -f $display)
  $alloc = JsonApi-POST $apiBase $headers "/v1/parties/allocate" @{
    identifierHint=$display; displayName=$display
  }
  $alloc.result.identifier
}

function Get-PackageIdFromDar([string]$darFile) {
  if (-not $darFile) { return $null }
  if (-not (Get-Command daml -ErrorAction SilentlyContinue)) { return $null }
  try {
    $jsonOut = & daml damlc inspect-dar "$darFile" --json 2>$null
    if ($LASTEXITCODE -eq 0 -and $jsonOut) {
      $obj = $jsonOut | ConvertFrom-Json -ErrorAction Stop
      $cands = @()
      $cands += $obj.main_package_id
      $cands += $obj.package_id
      if ($obj.packages) {
        $cands += ($obj.packages | ForEach-Object { $_.package_id, $_.hash, $_.packageId })
      }
      $pidCandidate = ($cands | Where-Object { $_ -match '^[0-9a-f]+$' } | Select-Object -First 1)
      if ($pidCandidate) { return $pidCandidate }
    }
  } catch {}
  try {
    $out = & daml damlc inspect-dar "$darFile" 2>$null
    foreach ($rx in @(
      '(?im)hash\s*:\s*([0-9a-f]{8,})',
      '(?im)package\s*id\s*:\s*([0-9a-f]{8,})'
    )) {
      $m = [regex]::Match($out, $rx)
      if ($m.Success) { return $m.Groups[1].Value }
    }
  } catch {}
  $null
}

function Discover-PackageIdViaApi([string]$apiBase, $headers) {
  try {
    $idsRaw = JsonApi-GET $apiBase $headers "/v1/packages"
    $idArr = Get-ResultArray $idsRaw

    foreach ($pkgId in $idArr) {
      try {
        $pkg = JsonApi-GET $apiBase $headers ("/v1/packages/$pkgId")
        $mods = $pkg.modules
        if ($mods) {
          foreach ($m in $mods) {
            if (($m -is [string] -and $m -eq "Main") -or ($m.name -eq "Main")) { return $pkgId }
          }
        }
      } catch {}
    }

    foreach ($pkgId in $idArr) {
      $body = @{ templateIds = @("$pkgId:Main:LogRequest"); query = @{} }
      try {
        JsonApi-POST $apiBase $headers "/v1/query" $body | Out-Null
        return $pkgId
      } catch {}
    }
  } catch {}
  $null
}

function Kill-ProcessOnPort([int]$port) {
  try {
    $conn = Get-NetTCPConnection -LocalPort $port -ErrorAction SilentlyContinue | Select-Object -First 1
    if ($conn) {
      $p = Get-Process -Id $conn.OwningProcess -ErrorAction SilentlyContinue
      if ($p) { Stop-Process -Id $p.Id -Force }
    }
  } catch {}
}

