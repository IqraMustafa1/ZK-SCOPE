-- ─────────────────────────────────────────────────────────────────────────────
-- Relay log

template RelayLog
  with
    operator             : Party
    edge                 : Party
    sp                   : Party
    senderId             : Text
    deviceOwner          : Party
    deviceKey            : Text
    bcCid                : ContractId BrokerContract
    digest               : Text
    ciphertextB64        : Text
    ephX25519Hex         : Text
    aad                  : Optional Text
    counter              : Int
    ts                   : Time
    epoch                : Int
    merkleRoot           : Text
    algId                : AlgId
    useZkPac             : Bool
    policyIdOpt          : Optional Text
    leafHashOpt          : Optional Text
    revealedAttrsHashOpt : Optional Text
    vkIdOpt              : Optional Text
    spSignatureB64       : Text
    spEd25519PubHex      : Text
    pqSignatureB64       : Optional Text
    pqPubKey             : Optional Text
    kyberCiphertextB64   : Optional Text
    acked                : Bool
  where
    signatory operator
    observer (operator :: deviceOwner :: sp :: [edge])

    key (operator, deviceKey, epoch, senderId, counter)
        : (Party, Text, Int, Text, Int)
    maintainer (case key of (op, _, _, _, _) -> op)

    nonconsuming choice Acknowledge : ContractId RelayLog
      controller operator
      do
        if acked then
          pure self
        else do
          archive self
          create (this with acked = True)

